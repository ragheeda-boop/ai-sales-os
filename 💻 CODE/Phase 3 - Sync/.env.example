# ═══════════════════════════════════════════════════════════════
# AI Sales OS v4.0 - Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# Apollo.io API
APOLLO_API_KEY=your_apollo_api_key_here

# Notion API
NOTION_API_KEY=your_notion_integration_token_here

# Notion Database IDs (from your Notion workspace URLs)
NOTION_DATABASE_ID_CONTACTS=your_contacts_database_id_here
NOTION_DATABASE_ID_COMPANIES=your_companies_database_id_here
NOTION_DATABASE_ID_TASKS=your_tasks_database_id_here
NOTION_DATABASE_ID_MEETINGS=your_meetings_database_id_here
NOTION_DATABASE_ID_OPPORTUNITIES=your_opportunities_database_id_here

# Optional: Sync settings
SYNC_INTERVAL_MINUTES=5
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════
# v4.0 — Apollo Sequence Settings (auto_sequence.py)
# ═══════════════════════════════════════════════════════════════

# Apollo Sequence IDs (mapped in auto_sequence.py SEQUENCE_MAP)
# These are configured in the script — no env vars needed

# Sender email accounts for round-robin (configured in auto_sequence.py)
# ragheed: ragheed@joinmuhide.com, ragheed@ratlfintech.com
# ibrahim: ibrahim@joinmuhide.com, ibrahim@muhide.com

# ═══════════════════════════════════════════════════════════════
# v4.1 — Meeting Tracker & Opportunity Manager
# ═══════════════════════════════════════════════════════════════

# Google Calendar credentials JSON (base64 encoded for GitHub Actions)
# For local development: path to service account or OAuth credentials JSON
GOOGLE_CALENDAR_CREDENTIALS=your_google_calendar_credentials_here
